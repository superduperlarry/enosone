# Copy to .env.local and fill in.

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Local SQLite path (defaults to ./enos.db)
# DATABASE_PATH=

# Model-key vault master key (32 bytes, base64) — generate with: openssl rand -base64 32
ENOS_MASTER_KEY=

# Stripe test keys (spend layer). Vault flow degrades gracefully without them.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Money-ops backend: mock (Phase A default) | agentos (real sandbox)
ENOS_BACKEND=mock
# AGENTOS_BASE_URL=https://sandbox.api.enosone.com/v1
# AGENTOS_OWNER_KEY=ok_test_...
